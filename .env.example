# Model providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_BASE_URL=

# Default models used by ./cli/aide-run (recommended for non-OpenAI providers)
AIDE_MODEL=
AIDE_FEEDBACK_MODEL=

# MLflow tracking (optional; local file store by default)
AIDE_ENABLE_MLFLOW=0
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=aide-public
MLFLOW_ARTIFACT_ROOT=

# Ray / cluster (optional for distributed mode)
AIDE_HEAD_NODE_IP=
AIDE_HEAD_HOST=localhost
AIDE_WORKER_HOSTS=
AIDE_SSH_USER=ubuntu
AIDE_RAY_PORT=6379
AIDE_DASHBOARD_PORT=8265
AIDE_NUM_GPUS_PER_NODE=8
AIDE_OBJECT_STORE_MEMORY=10000000000

# KernelBench path overrides (optional)
KERNELBENCH_PATH=
KERNELBENCH_DATASET_PATH=

# AlgoTune path override (optional; defaults to tasks/algotune/vendor/AlgoTune)
ALGOTUNE_PATH=
