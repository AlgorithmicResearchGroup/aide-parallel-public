#!/usr/bin/env bash
# Deterministic local setup check for first-time users.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

echo "Checking Python imports..."
python -c "import aide, ray, torch, yaml, dotenv; print('Imports OK')"

echo "Running baseline attention evaluation on CPU..."
(
  cd "${REPO_ROOT}"
  AIDE_ATTENTION_FAST_EVAL=1 \
  AIDE_ENABLE_MLFLOW=0 \
  AIDE_PROJECT_ROOT="${REPO_ROOT}" \
  python tasks/attention/evaluate.py --solution-path tasks/attention/optimize.py --device cpu
)

echo "Setup check passed."
