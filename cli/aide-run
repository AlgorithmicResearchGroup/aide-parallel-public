#!/usr/bin/env bash
# Public entrypoint for running AIDE experiments.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON_BIN="${PYTHON_BIN:-$(command -v python)}"

TASK="attention"
HEAD_NODE_IP="${AIDE_HEAD_NODE_IP:-}"
CONTRACT_FILE=""
NUM_EXPERIMENTS=""
NUM_ITERATIONS=""
STEPS=""
GPU_FRACTION=""
CPUS_PER_EXPERIMENT=""
TRACKING_EXPERIMENT=""
MODEL="${AIDE_MODEL:-}"
FEEDBACK_MODEL="${AIDE_FEEDBACK_MODEL:-}"
KB_TASK=""
AT_TASK=""
RESULT_JSON=""
LOCAL_MODE="false"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --task)
      TASK="$2"; shift 2 ;;
    --contract)
      CONTRACT_FILE="$2"; shift 2 ;;
    --head-node-ip)
      HEAD_NODE_IP="$2"; shift 2 ;;
    --num-experiments)
      NUM_EXPERIMENTS="$2"; shift 2 ;;
    --num-iterations)
      NUM_ITERATIONS="$2"; shift 2 ;;
    --steps)
      STEPS="$2"; shift 2 ;;
    --gpu-fraction)
      GPU_FRACTION="$2"; shift 2 ;;
    --cpus-per-experiment)
      CPUS_PER_EXPERIMENT="$2"; shift 2 ;;
    --tracking-experiment|--wandb-project)
      TRACKING_EXPERIMENT="$2"; shift 2 ;;
    --model)
      MODEL="$2"; shift 2 ;;
    --feedback-model)
      FEEDBACK_MODEL="$2"; shift 2 ;;
    --kb-task)
      KB_TASK="$2"; shift 2 ;;
    --at-task)
      AT_TASK="$2"; shift 2 ;;
    --at-n-problems|--at-n-runs|--at-mode|--at-fast|--no-at-fast)
      echo "ERROR: Repo-owned non-strict AlgoTune options have been removed. This repo now runs AlgoTune only in publication-grade strict mode."
      exit 1 ;;
    --result-json)
      RESULT_JSON="$2"; shift 2 ;;
    --local)
      LOCAL_MODE="true"; shift ;;
    --help)
      cat <<'USAGE'
Usage: ./cli/aide-run [OPTIONS]

Options:
  --task TASK              Task to run (attention, kernel, kernelbench, algotune)
  --contract FILE          Contract filename inside tasks/<task>/
  --head-node-ip IP        Ray head-node IP (default: $AIDE_HEAD_NODE_IP)
  --num-experiments N      Override number of parallel experiments
  --num-iterations N       Override number of iterations
  --steps N                Override steps per experiment
  --gpu-fraction N         GPU fraction per experiment (0.5=2 per GPU)
  --cpus-per-experiment N  CPUs per experiment in CPU mode
  --tracking-experiment N  MLflow experiment name override
  --model NAME             Generation model override
  --feedback-model NAME    Feedback model override
  --kb-task ID             KernelBench task ID (required for kernelbench)
  --at-task NAME           AlgoTune task name (required for algotune)
  --result-json FILE       Write final run metadata to FILE
  --local                  Run locally (no remote Ray address)
  --help                   Show this message

Examples:
  ./cli/aide-run --local --num-experiments 2 --steps 1
  ./cli/aide-run --task kernelbench --kb-task 1_19 --head-node-ip 10.0.0.5
  ./cli/aide-run --local --task algotune --at-task kmeans --cpus-per-experiment 2
USAGE
      exit 0 ;;
    *)
      echo "Unknown option: $1"
      exit 1 ;;
  esac
done

if [[ "$TASK" == "kernelbench" && -z "$KB_TASK" ]]; then
  echo "ERROR: --kb-task is required for --task kernelbench"
  exit 1
fi

if [[ "$TASK" == "algotune" && -z "$AT_TASK" ]]; then
  echo "ERROR: --at-task is required for --task algotune"
  exit 1
fi

if [[ -z "$CONTRACT_FILE" ]]; then
  if [[ -f "${REPO_ROOT}/tasks/$TASK/contract_gpu.yaml" ]]; then
    CONTRACT_FILE="contract_gpu.yaml"
  else
    CONTRACT_FILE="contract.yaml"
  fi
fi

SOURCE_CONTRACT="${REPO_ROOT}/tasks/$TASK/$CONTRACT_FILE"
TARGET_CONTRACT="${REPO_ROOT}/tasks/$TASK/contract.yaml"

if [[ ! -f "$SOURCE_CONTRACT" ]]; then
  echo "ERROR: Contract file not found: ${REPO_ROOT}/tasks/$TASK/$CONTRACT_FILE"
  exit 1
fi

if [[ "$SOURCE_CONTRACT" != "$TARGET_CONTRACT" ]]; then
  cp "$SOURCE_CONTRACT" "$TARGET_CONTRACT"
fi

echo "Using task=$TASK contract=$CONTRACT_FILE"
echo "Using python=${PYTHON_BIN}"

CMD=("${PYTHON_BIN}" "${REPO_ROOT}/src/aide_runner.py" --task "$TASK")

if [[ "$LOCAL_MODE" == "true" ]]; then
  CMD+=(--local)
elif [[ -n "$HEAD_NODE_IP" ]]; then
  CMD+=(--head-node-ip "$HEAD_NODE_IP")
fi

[[ -n "$NUM_EXPERIMENTS" ]] && CMD+=(--num-experiments "$NUM_EXPERIMENTS")
[[ -n "$NUM_ITERATIONS" ]] && CMD+=(--num-iterations "$NUM_ITERATIONS")
[[ -n "$STEPS" ]] && CMD+=(--steps "$STEPS")
[[ -n "$GPU_FRACTION" ]] && CMD+=(--gpu-fraction "$GPU_FRACTION")
[[ -n "$CPUS_PER_EXPERIMENT" ]] && CMD+=(--cpus-per-experiment "$CPUS_PER_EXPERIMENT")
[[ -n "$TRACKING_EXPERIMENT" ]] && CMD+=(--tracking-experiment "$TRACKING_EXPERIMENT")
[[ -n "$MODEL" ]] && CMD+=(--model "$MODEL")
[[ -n "$FEEDBACK_MODEL" ]] && CMD+=(--feedback-model "$FEEDBACK_MODEL")
[[ -n "$KB_TASK" ]] && CMD+=(--kb-task "$KB_TASK")
[[ -n "$AT_TASK" ]] && CMD+=(--at-task "$AT_TASK")
[[ -n "$RESULT_JSON" ]] && CMD+=(--result-json "$RESULT_JSON")

if [[ "$LOCAL_MODE" != "true" && -n "$HEAD_NODE_IP" ]]; then
  echo "Checking Ray cluster at ${HEAD_NODE_IP}:6379 ..."
  if ! "${PYTHON_BIN}" -c "import ray; ray.init(address='${HEAD_NODE_IP}:6379'); print('Cluster reachable'); ray.shutdown()" >/dev/null 2>&1; then
    echo "ERROR: Ray cluster is not reachable at ${HEAD_NODE_IP}:6379"
    echo "Tip: start local mode with --local, or export AIDE_HEAD_NODE_IP correctly."
    exit 1
  fi
fi

echo "Executing: ${CMD[*]}"
"${CMD[@]}"
