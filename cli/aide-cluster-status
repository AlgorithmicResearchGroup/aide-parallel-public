#!/usr/bin/env bash
# Show Ray cluster status from a topology config.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON_BIN="${PYTHON_BIN:-$(command -v python)}"

CLUSTER_CONFIG=""
JSON_OUTPUT="false"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --cluster-config)
      CLUSTER_CONFIG="$2"; shift 2 ;;
    --json)
      JSON_OUTPUT="true"; shift ;;
    --help)
      cat <<'USAGE'
Usage: ./cli/aide-cluster-status --cluster-config FILE [--json]
USAGE
      exit 0 ;;
    *)
      echo "Unknown option: $1"
      exit 1 ;;
  esac
done

if [[ -z "$CLUSTER_CONFIG" ]]; then
  echo "ERROR: --cluster-config is required"
  exit 1
fi

CMD=("${PYTHON_BIN}" "${REPO_ROOT}/src/cluster_gpu_status.py" --cluster-config "$CLUSTER_CONFIG")
if [[ "$JSON_OUTPUT" == "true" ]]; then
  CMD+=(--json)
fi
exec "${CMD[@]}"
