#!/usr/bin/env python3
"""Generate a strict eager baseline timing artifact for KernelBench."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


def main() -> int:
    parser = argparse.ArgumentParser(description="Generate an eager baseline timing artifact for KernelBench")
    parser.add_argument("--hardware-name", required=True, help="Output timing directory name under results/timing/")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON only")
    args = parser.parse_args()

    script_dir = Path(__file__).resolve().parent
    repo_root = script_dir.parent
    if str(repo_root) not in sys.path:
        sys.path.insert(0, str(repo_root))
    from tasks.kernelbench.strict_benchmark import generate_eager_baseline  # noqa: WPS433

    baseline_path = generate_eager_baseline(hardware_name=args.hardware_name)
    payload = {
        "status": "ok",
        "baseline_path": str(baseline_path),
        "hardware_name": args.hardware_name,
        "note": "Generated eager baseline_time_torch.json using vendored KernelBench baseline machinery (levels 1-3).",
    }
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"KernelBench eager baseline generated: {baseline_path}")
        print("Note: the vendored baseline generator currently covers levels 1-3.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
