#!/usr/bin/env bash

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON_BIN="${PYTHON_BIN:-$(command -v python)}"

TASK_NAME=""
FORCE_FLAG="0"
LAZY_FLAG="0"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --task)
      TASK_NAME="$2"; shift 2 ;;
    --force)
      FORCE_FLAG="1"; shift ;;
    --lazy)
      LAZY_FLAG="1"; shift ;;
    --help)
      cat <<'USAGE'
Usage: ./cli/aide-algotune-fetch-dataset [OPTIONS]

Options:
  --task NAME   Fetch only one AlgoTune task dataset
  --force       Force a fresh Hugging Face snapshot pull
  --lazy        Fetch only JSONL metadata initially
  --help        Show this message
USAGE
      exit 0 ;;
    *)
      echo "Unknown option: $1"
      exit 1 ;;
  esac
done

if [[ "${ALGOTUNE_HF_REVISION:-main}" == "main" ]]; then
  echo "ERROR: ALGOTUNE_HF_REVISION must be pinned to a non-'main' revision before fetching."
  exit 1
fi

echo "Using python=${PYTHON_BIN}"
echo "Fetching AlgoTune dataset snapshot locally"

TASK_NAME="${TASK_NAME}" FORCE_FLAG="${FORCE_FLAG}" LAZY_FLAG="${LAZY_FLAG}" REPO_ROOT="${REPO_ROOT}" "${PYTHON_BIN}" - <<'PY'
import os
import sys
from pathlib import Path

repo_root = Path(os.environ["REPO_ROOT"])
sys.path.insert(0, str(repo_root / "tasks" / "algotune" / "vendor" / "AlgoTune"))

from AlgoTuner.utils.hf_datasets import fetch_hf_dataset

task_name = os.environ.get("TASK_NAME") or None
force = os.environ.get("FORCE_FLAG") == "1"
lazy = os.environ.get("LAZY_FLAG") == "1"

if lazy:
    os.environ["ALGOTUNE_HF_LAZY"] = "1"
else:
    os.environ.pop("ALGOTUNE_HF_LAZY", None)

snapshot_path = fetch_hf_dataset(task_name, force=force)
print(snapshot_path)
PY
