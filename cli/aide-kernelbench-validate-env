#!/usr/bin/env python3
"""Validate the local KernelBench strict benchmark environment."""

from __future__ import annotations

import argparse
import json
import shlex
import subprocess
import sys
from pathlib import Path


def _run_host_validation(host: str, ssh_user: str, command: list[str], workdir: str | None = None) -> dict:
    if host in {"localhost", "127.0.0.1"}:
        result = subprocess.run(command, capture_output=True, text=True)
    else:
        remote_cmd = " ".join(shlex.quote(part) for part in command)
        if workdir:
            remote_cmd = f"cd {shlex.quote(workdir)} && {remote_cmd}"
        result = subprocess.run(
            ["ssh", f"{ssh_user}@{host}", "bash", "-lc", remote_cmd],
            capture_output=True,
            text=True,
        )
    if result.returncode not in {0, 1}:
        raise RuntimeError(result.stderr.strip() or result.stdout.strip() or f"Validation command failed on {host}")
    return json.loads(result.stdout)


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate the KernelBench strict benchmark environment")
    parser.add_argument("--kb-task", default=None, help="Optional task id to validate against baseline coverage")
    parser.add_argument("--kb-baseline-path", default=None, help="Path to explicit KernelBench baseline JSON")
    parser.add_argument("--kb-reference-baseline", default=None, help="Vendored reference baseline directory name")
    parser.add_argument("--cluster-config", default=None, help="YAML topology file for local or submit-only cluster mode")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON only")
    args = parser.parse_args()

    script_dir = Path(__file__).resolve().parent
    repo_root = script_dir.parent
    if str(repo_root) not in sys.path:
        sys.path.insert(0, str(repo_root))
    from src.cluster_topology import load_cluster_topology  # noqa: WPS433
    from tasks.kernelbench.strict_benchmark import validate_benchmark_environment  # noqa: WPS433

    topology = load_cluster_topology(args.cluster_config)
    if topology and not topology.is_local:
        python_bin = topology.python_bin or "python"
        remote_repo_root = Path(topology.working_dir or repo_root)
        command = [
            python_bin,
            str(remote_repo_root / "cli" / "aide-kernelbench-validate-env"),
            "--json",
        ]
        if args.kb_task:
            command.extend(["--kb-task", args.kb_task])
        if args.kb_baseline_path:
            command.extend(["--kb-baseline-path", args.kb_baseline_path])
        if args.kb_reference_baseline:
            command.extend(["--kb-reference-baseline", args.kb_reference_baseline])

        node_results = []
        errors = []
        for node in topology.nodes:
            try:
                result = _run_host_validation(
                    node.host,
                    topology.ssh_user,
                    command,
                    workdir=str(remote_repo_root),
                )
                node_results.append({
                    "host": node.host,
                    "role": node.role,
                    "ok": result.get("ok", False),
                    "result": result,
                })
                if not result.get("ok", False):
                    errors.append(f"{node.host}: validation failed")
            except Exception as exc:  # pragma: no cover - CLI wrapper
                node_results.append({
                    "host": node.host,
                    "role": node.role,
                    "ok": False,
                    "error": str(exc),
                })
                errors.append(f"{node.host}: {exc}")

        payload = {
            "ok": not errors,
            "mode": "cluster",
            "cluster_config": topology.config_path,
            "head_ip": topology.head_ip,
            "nodes": node_results,
            "errors": errors,
        }
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
        else:
            print(f"KernelBench strict benchmark environment: {'OK' if payload['ok'] else 'FAILED'}")
            print(f"Cluster config: {topology.config_path}")
            print(f"Head IP: {topology.head_ip}")
            for item in node_results:
                status = "OK" if item.get("ok") else "FAILED"
                print(f" - {item['host']} ({item['role']}): {status}")
                if item.get("error"):
                    print(f"   {item['error']}")
            if errors:
                print("Errors:")
                for error in errors:
                    print(f" - {error}")
        return 0 if payload["ok"] else 1

    result = validate_benchmark_environment(
        baseline_path=args.kb_baseline_path,
        reference_baseline=args.kb_reference_baseline,
        task_id=args.kb_task,
    )
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        status = "OK" if result["ok"] else "FAILED"
        print(f"KernelBench strict benchmark environment: {status}")
        runtime = result["runtime"]
        print(f"Python: {runtime['python_version']}")
        print(f"PyTorch: {runtime['torch_version']}")
        print(f"CUDA: {runtime['cuda_version']}")
        print(f"GPU: {runtime['gpu_name']}")
        print(f"KernelBench root: {runtime['kernelbench_root']}")
        print(f"Dataset root: {runtime['dataset_root']}")
        print(f"Baseline: {result['baseline_path']}")
        if result["errors"]:
            print("Errors:")
            for error in result["errors"]:
                print(f" - {error}")
        if result["warnings"]:
            print("Warnings:")
            for warning in result["warnings"]:
                print(f" - {warning}")
    return 0 if result["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
